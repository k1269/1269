// 2. التحقق من حالة المستخدم
auth.onAuthStateChanged(async (user) => {
    if (!user) {
        // المستخدم غير مسجل دخول: أظهر زر تسجيل الدخول
        document.getElementById('login-btn').style.display = 'block';
        return;
    }

    // المستخدم مسجل دخول: افحص القاعدة
    const userDoc = await getDoc(doc(db, "users", user.uid));

    if (!userDoc.exists()) {
        // جديد: أظهر نموذج تسجيل اسم اللاعب
        document.getElementById('registration-form').style.display = 'block';
    } else {
        const userData = userDoc.data();
        if (userData.status === 'approved') {
            // مقبول: أظهر المحتوى
            document.getElementById('portal-content').style.display = 'block';
            setWatermark(userData.name); // تفعيل الووترمارك باسمه
        } else {
            // معلق: أظهر رسالة الانتظار
            document.getElementById('pending-msg').style.display = 'block';
        }
    }
});




