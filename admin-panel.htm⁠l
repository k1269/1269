<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <title>Admin Dashboard</title>
    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/9.0.0/firebase-app.js";
        import { getFirestore, collection, query, where, getDocs, doc, updateDoc } from "https://www.gstatic.com/firebasejs/9.0.0/firebase-firestore.js";
        import { getAuth } from "https://www.gstatic.com/firebasejs/9.0.0/firebase-auth.js";

        const firebaseConfig = {
            apiKey: "AIzaSyA9WCd_D9kKxFb6xP4IcWK46itFWNOuU5g",
            authDomain: "kingdom-1269-portal.firebaseapp.com",
            projectId: "kingdom-1269-portal",
            storageBucket: "kingdom-1269-portal.firebasestorage.app",
            messagingSenderId: "1007373803222",
            appId: "1:1007373803222:web:bcb85595a99da596aaf377"
        };

        const app = initializeApp(firebaseConfig);
        const db = getFirestore();
        const auth = getAuth();

        async function loadPendingUsers() {
            const q = query(collection(db, "users"), where("status", "==", "pending"));
            const querySnapshot = await getDocs(q);
            const list = document.getElementById('pending-list');
            list.innerHTML = '';
            
            querySnapshot.forEach((docSnap) => {
                const user = docSnap.data();
                const div = document.createElement('div');
                div.style = "padding: 10px; border-bottom: 1px solid #334155;";
                div.innerHTML = `
                    <span>${user.name} (${user.email})</span>
                    <button onclick="approve('${docSnap.id}')" style="background:#10b981;">موافقة</button>
                `;
                list.appendChild(div);
            });
        }

        window.approve = async (uid) => {
            await updateDoc(doc(db, "users", uid), { status: 'approved' });
            alert("تم قبول اللاعب!");
            loadPendingUsers();
        };

        auth.onAuthStateChanged(user => {
            if (!user) window.location.href = "index.html";
            loadPendingUsers();
        });
    </script>
    <style>
        body { background: #0f172a; color: white; font-family: sans-serif; padding: 20px; }
    </style>
</head>
<body>
    <h1>لوحة تحكم الإدارة</h1>
    <div id="pending-list">جاري تحميل الطلبات...</div>
    <br>
    <a href="index.html" style="color:#94a3b8;">العودة للرئيسية</a>
</body>
</html>
