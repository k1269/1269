<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Kingdom 1269 | Admin Dashboard</title>
    <style>
        :root { --gold: #C5A059; --bg: #050505; --dark-blue: #0A0F1A; --text: #E0E0E0; }
        body { background-color: var(--bg); color: var(--text); font-family: 'Segoe UI', sans-serif; padding: 20px; }
        h1 { color: var(--gold); text-align: center; }
        
        table { width: 100%; border-collapse: collapse; background: var(--dark-blue); margin-top: 20px; }
        th, td { border: 1px solid #333; padding: 12px; text-align: center; }
        th { background: #1a1a1a; color: var(--gold); }
        
        .btn-approve { background: var(--gold); border: none; padding: 8px 15px; cursor: pointer; color: black; font-weight: bold; }
        .btn-approve:hover { opacity: 0.8; }
        
        .status-pending { color: #ffcc00; }
        .status-member { color: #4caf50; }
        
        .back-link { display: block; text-align: center; margin-top: 30px; color: var(--gold); text-decoration: none; }
    </style>
</head>
<body>

    <h1>Admin Dashboard</h1>
    <a href="command-center.html" class="back-link">← Back to Command Center</a>

    <table id="userTable">
        <thead>
            <tr>
                <th>In-Game Name</th>
                <th>Email</th>
                <th>Role</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody id="userList">
            </tbody>
    </table>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js";
        import { getAuth, onAuthStateChanged } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-auth.js";
        import { getFirestore, collection, getDocs, doc, updateDoc, getDoc } from "https://www.gstatic.com/firebasejs/10.7.1/firebase-firestore.js";

        const firebaseConfig = { 
            apiKey: "AIzaSyA9WCd_D9kKxFb6xP4IcWK46itFWNOuU5g",
            authDomain: "kingdom-1269-portal.firebaseapp.com",
            projectId: "kingdom-1269-portal",
            storageBucket: "kingdom-1269-portal.firebasestorage.app",
            messagingSenderId: "1007373803222",
            appId: "1:1007373803222:web:bcb85595a99da596aaf377" 
        };
        
        const app = initializeApp(firebaseConfig);
        const auth = getAuth();
        const db = getFirestore();

        onAuthStateChanged(auth, async (user) => {
            if (!user) { window.location.href = "index.html"; return; }

            // التحقق إذا كان المستخدم أدمن
            const adminDoc = await getDoc(doc(db, "users", user.uid));
            if (!adminDoc.exists() || adminDoc.data().role !== 'admin') {
                alert("Access Denied!");
                window.location.href = "index.html";
                return;
            }

            // جلب المستخدمين
            const querySnapshot = await getDocs(collection(db, "users"));
            const tbody = document.getElementById('userList');
            
            querySnapshot.forEach((doc) => {
                const data = doc.data();
                const row = document.createElement('tr');
                row.innerHTML = `
                    <td>${data.inGameName || 'N/A'}</td>
                    <td>${data.email}</td>
                    <td class="status-${data.role}">${data.role}</td>
                    <td>${data.role === 'pending' ? `<button class="btn-approve" onclick="approveUser('${doc.id}')">Approve</button>` : 'Approved'}</td>
                `;
                tbody.appendChild(row);
            });
        });

        // دالة الترقية
        window.approveUser = async (userId) => {
            await updateDoc(doc(db, "users", userId), { role: "member" });
            location.reload(); // تحديث الصفحة
        };
    </script>
</body>
</html>
